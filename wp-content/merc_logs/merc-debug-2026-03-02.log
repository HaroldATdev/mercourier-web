t\t\t\t\t\t\t\t<img width=\"1024\" height=\"1024\" src=\"https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-20-at-7.17.17-PM-1.jpeg\" class=\"attachment-large size-large wp-image-6495\" alt=\"\" srcset=\"https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-20-at-7.17.17-PM-1.jpeg 1024w, https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-20-at-7.17.17-PM-1-300x300.jpeg 300w, https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-20-at-7.17.17-PM-1-150x150.jpeg 150w, https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-20-at-7.17.17-PM-1-768x768.jpeg 768w\" sizes=\"(max-width: 1024px) 100vw, 1024px\" \/>\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-f75dbcb e-con-full e-flex e-con e-child\" data-id=\"f75dbcb\" data-element_type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-76332c0 elementor-widget elementor-widget-heading\" data-id=\"76332c0\" data-element_type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">MERC EMPRENDEDOR<\/h2>\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-acac219 e-con-full e-flex e-con e-child\" data-id=\"acac219\" data-element_type=\"container\">\n\t\t[elementor-element k=\"f0ed140f8b6c5ed68b460c37d284d5b3\" data=\"\"]\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-d787e83 elementor-widget__width-initial elementor-widget elementor-widget-html\" data-id=\"d787e83\" data-element_type=\"widget\" data-widget_type=\"html.default\">\n\t\t\t\t\t<div class=\"marco-premium\">\n  <div class=\"neon-red-flow\"><\/div>\n  \n  <a href=\"https:\/\/wa.me\/51931430389?text=Hola,%20\u00bfc\u00f3mo%20est\u00e1n?%20Me%20gustar\u00eda%20solicitar%20el%20servicio%20Merc%20Emprendedor.%20Me%20interesa%20la%20tarifa%20plana%20de%20S\/%2010%20para%20Lima%20y%20Callao%20con%20entrega%20el%20mismo%20d\u00eda.%F0%9F%93%A6%E2%9C%A8\" \n  class=\"boton-blanco-top\" target=\"_blank\">\n    COTIZA AHORA\n  <\/a>\n<\/div>\n\n<style>\n\/* Contenedor principal con fondo transparente *\/\n.marco-premium {\n  position: relative;\n  width: 290px;\n  height: 85px;\n  background: transparent; \/* Fondo transparente como pediste *\/\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  border-radius: 15px;\n  overflow: hidden;\n  border: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n\/* El haz de luz roja que da vueltas *\/\n.neon-red-flow {\n  position: absolute;\n  width: 150px;\n  height: 500px;\n  background: linear-gradient(#ff0000, #ff0000);\n  animation: girar 3s linear infinite;\n}\n\n\/* Efecto difuminado para que la luz roja sea \"ne\u00f3n\" *\/\n.neon-red-flow::after {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background: #ff0000;\n  filter: blur(25px);\n  opacity: 0.8;\n}\n\n@keyframes girar {\n  from { transform: rotate(0deg); }\n  to { transform: rotate(360deg); }\n}\n\n\/* El hueco interno transparente entre la luz y el bot\u00f3n *\/\n.marco-premium::before {\n  content: '';\n  position: absolute;\n  inset: 5px; \/* Espacio est\u00e9tico donde se ve la luz *\/\n  background: rgba(0, 0, 0, 0.2); \/* Negro muy suave y transparente *\/\n  border-radius: 12px;\n  z-index: 1;\n}\n\n\/* El bot\u00f3n blanco llamativo *\/\n.boton-blanco-top {\n  position: relative;\n  z-index: 2;\n  padding: 12px 35px;\n  background: #ffffff; \/* Blanco s\u00f3lido mantenido *\/\n  color: #000000;\n  text-decoration: none;\n  font-family: 'Arial', sans-serif;\n  font-weight: 900;\n  font-size: 17px;\n  letter-spacing: 1px;\n  border-radius: 8px;\n  transition: 0.4s;\n  box-shadow: 0 5px 15px rgba(0,0,0,0.4);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n\/* Efecto cuando pasas el mouse *\/\n.boton-blanco-top:hover {\n  transform: scale(1.08);\n  background: #ff0000;\n  color: #ffffff;\n  box-shadow: 0 0 20px #ff0000;\n}\n<\/style>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-8e91e52 e-grid e-con-full e-con e-child\" data-id=\"8e91e52\" data-element_type=\"container\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;}\">\n\t\t<div class=\"elementor-element elementor-element-b4641fd e-con-full e-flex e-con e-child\" data-id=\"b4641fd\" data-element_type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-68543a8 elementor-widget elementor-widget-heading\" data-id=\"68543a8\" data-element_type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">FAQ MERC EMPRENDEDOR<\/h2>\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-a7379c2 elementor-widget elementor-widget-accordion\" data-id=\"a7379c2\" data-element_type=\"widget\" data-widget_type=\"accordion.default\">\n\t\t\t\t\t\t\t<div class=\"elementor-accordion\">\n\t\t\t\t\t\t\t<div class=\"elementor-accordion-item\">\n\t\t\t\t\t<div id=\"elementor-tab-title-1751\" class=\"elementor-tab-title\" data-tab=\"1\" role=\"button\" aria-controls=\"elementor-tab-content-1751\" aria-expanded=\"false\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon elementor-accordion-icon-right\" aria-hidden=\"true\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon-closed\"><svg class=\"e-font-icon-svg e-fas-plus\" viewBox=\"0 0 448 512\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\"><path d=\"M416 208H272V64c0-17.67-14.33-32-32-32h-32c-17.67 0-32 14.33-32 32v144H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h144v144c0 17.67 14.33 32 32 32h32c17.67 0 32-14.33 32-32V304h144c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z\"><\/path><\/svg><\/span>\n\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon-opened\"><svg class=\"e-font-icon-svg e-fas-minus\" viewBox=\"0 0 448 512\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\"><path d=\"M416 208H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h384c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z\"><\/path><\/svg><\/span>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<\/span>\n\t\t\t\t\t\t\t\t\t\t\t\t<a class=\"elementor-accordion-title\" tabindex=\"0\">\u00bfPor qu\u00e9 elegir el servicio MERC Emprendedor?<\/a>\n\t\t\t\t\t<\/div>\n\t\t\t\t\t<div id=\"elementor-tab-content-1751\" class=\"elementor-tab-content elementor-clearfix\" data-tab=\"1\" role=\"region\" aria-labelledby=\"elementor-tab-title-1751\"><p>Es la opci\u00f3n ideal si buscas <b><i>comodidad y rapidez<\/i><\/b>, ya que enviamos un motorizado a tu ubicaci\u00f3n para recoger tus paquetes. Te permite cumplir con tus clientes el mismo d\u00eda con una<i><b> tarifa plana de S\/ 10.00 en todo Lima y Callao,<\/b><\/i> sin exigencia de un m\u00ednimo de env\u00edos.<\/p><\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t\t\t<div class=\"elementor-accordion-item\">\n\t\t\t\t\t<div id=\"elementor-tab-title-1752\" class=\"elementor-tab-title\" data-tab=\"2\" role=\"button\" aria-controls=\"elementor-tab-content-1752\" aria-expanded=\"false\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon elementor-accordion-icon-right\" aria-hidden=\"true\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon-closed\"><svg class=\"e-font-icon-svg e-fas-plus\" viewBox=\"0 0 448 512\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\"><path d=\"M416 208H272V64c0-17.67-14.33-32-32-32h-32c-17.67 0-32 14.33-32 32v144H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h144v144c0 17.67 14.33 32 32 32h32c17.67 0 32-14.33 32-32V304h144c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z\"><\/path><\/svg><\/span>\n\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon-opened\"><svg class=\"e-font-icon-svg e-fas-minus\" viewBox=\"0 0 448 512\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\"><path d=\"M416 208H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h384c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z\"><\/path><\/svg><\/span>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<\/span>\n\t\t\t\t\t\t\t\t\t\t\t\t<a class=\"elementor-accordion-title\" tabindex=\"0\">\u00bfQu\u00e9 seguridad tengo sobre mis productos y mi dinero?<\/a>\n\t\t\t\t\t<\/div>\n\t\t\t\t\t<div id=\"elementor-tab-content-1752\" class=\"elementor-tab-content elementor-clearfix\" data-tab=\"2\" role=\"region\" aria-labelledby=\"elementor-tab-title-1752\"><p data-path-to-node=\"4\"><span data-path-to-node=\"4,1\"><span class=\"citation-186\">Tus productos viajan protegidos con un <\/span><b data-path-to-node=\"4,1\" data-index-in-node=\"39\"><span class=\"citation-186\">seguro gratuito<\/span><\/b><span class=\"citation-186\"> que cubre robo, p\u00e9rdida o da\u00f1os materiales hasta por S\/ 300.00<\/span><\/span><span data-path-to-node=\"4,3\">. <\/span><span data-path-to-node=\"4,5\"><span class=\"citation-185\">Adem\u00e1s, garantizamos tu liquidez realizando el dep\u00f3sito de tus ventas cobradas mediante contra entrega el mismo d\u00eda<\/span><\/span><span data-path-to-node=\"4,7\">.<\/span><\/p><\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t\t\t<div class=\"elementor-accordion-item\">\n\t\t\t\t\t<div id=\"elementor-tab-title-1753\" class=\"elementor-tab-title\" data-tab=\"3\" role=\"button\" aria-controls=\"elementor-tab-content-1753\" aria-expanded=\"false\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon elementor-accordion-icon-right\" aria-hidden=\"true\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon-closed\"><svg class=\"e-font-icon-svg e-fas-plus\" viewBox=\"0 0 448 512\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\"><path d=\"M416 208H272V64c0-17.67-14.33-32-32-32h-32c-17.67 0-32 14.33-32 32v144H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h144v144c0 17.67 14.33 32 32 32h32c17.67 0 32-14.33 32-32V304h144c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z\"><\/path><\/svg><\/span>\n\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon-opened\"><svg class=\"e-font-icon-svg e-fas-minus\" viewBox=\"0 0 448 512\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\"><path d=\"M416 208H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h384c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z\"><\/path><\/svg><\/span>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<\/span>\n\t\t\t\t\t\t\t\t\t\t\t\t<a class=\"elementor-accordion-title\" tabindex=\"0\">\u00bfC\u00f3mo funciona la log\u00edstica de recojo y entrega?<\/a>\n\t\t\t\t\t<\/div>\n\t\t\t\t\t<div id=\"elementor-tab-content-1753\" class=\"elementor-tab-content elementor-clearfix\" data-tab=\"3\" role=\"region\" aria-labelledby=\"elementor-tab-title-1753\"><p data-path-to-node=\"6\"><span data-path-to-node=\"6,1\"><span class=\"citation-184\">Solo debes solicitarlo antes de las 9:30 am para que recojamos tu mercader\u00eda entre las 10:00 am y 12:30 pm<\/span><\/span><span data-path-to-node=\"6,3\">. <\/span><span data-path-to-node=\"6,5\"><span class=\"citation-183\">Las entregas se realizan esa misma tarde, en un rango de 2:00 pm a 7:30 pm, envi\u00e1ndote una foto como respaldo de cada entrega exitosa<\/span><\/span><span data-path-to-node=\"6,7\">.<\/span><\/p><\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-27a94fe e-con-full e-flex e-con e-child\" data-id=\"27a94fe\" data-element_type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-54e388e elementor-widget elementor-widget-image\" data-id=\"54e388e\" data-element_type=\"widget\" data-widget_type=\"image.default\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<img width=\"1024\" height=\"1024\" src=\"https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-20-at-7.17.17-PM-2.jpeg\" class=\"attachment-large size-large wp-image-6496\" alt=\"\" srcset=\"https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-20-at-7.17.17-PM-2.jpeg 1024w, https: