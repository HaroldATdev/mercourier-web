t_type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-57a54c9 elementor-widget elementor-widget-image\" data-id=\"57a54c9\" data-element_type=\"widget\" data-widget_type=\"image.default\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<img width=\"1024\" height=\"1024\" src=\"https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-20-at-7.17.18-PM-1.jpeg\" class=\"attachment-large size-large wp-image-6491\" alt=\"\" srcset=\"https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-20-at-7.17.18-PM-1.jpeg 1024w, https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-20-at-7.17.18-PM-1-300x300.jpeg 300w, https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-20-at-7.17.18-PM-1-150x150.jpeg 150w, https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-20-at-7.17.18-PM-1-768x768.jpeg 768w\" sizes=\"(max-width: 1024px) 100vw, 1024px\" \/>\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-7f8ba0d e-con-full e-flex e-con e-child\" data-id=\"7f8ba0d\" data-element_type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-f5f51c6 elementor-widget elementor-widget-heading\" data-id=\"f5f51c6\" data-element_type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">MERC FULLFILLMENT<\/h2>\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-a12f8fd e-con-full e-flex e-con e-child\" data-id=\"a12f8fd\" data-element_type=\"container\">\n\t\t[elementor-element k=\"f0ed140f8b6c5ed68b460c37d284d5b3\" data=\"\"]\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-bf14955 elementor-widget__width-initial elementor-widget elementor-widget-html\" data-id=\"bf14955\" data-element_type=\"widget\" data-widget_type=\"html.default\">\n\t\t\t\t\t<div class=\"marco-premium\">\n  <div class=\"neon-red-flow\"><\/div>\n  \n  <a href=\"https:\/\/wa.me\/51931430389?text=Hola,%20\u00bfc\u00f3mo%20est\u00e1n?%20Me%20gustar\u00eda%20solicitar%20el%20servicio%20MERC%20Fullfillment.%20Me%20interesa%20delegar%20mi%20operaci\u00f3n%20log\u00edstica,%20el%20almacenamiento%20estrat\u00e9gico%20de%20mis%20productos%20y%20la%20gesti\u00f3n%20integral%20de%20mi%20inventario.\" \n  class=\"boton-blanco-top\" target=\"_blank\">\n    COTIZA AHORA\n  <\/a>\n<\/div>\n\n<style>\n\/* Contenedor principal con fondo transparente *\/\n.marco-premium {\n  position: relative;\n  width: 290px;\n  height: 85px;\n  background: transparent; \/* Fondo transparente como pediste *\/\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  border-radius: 15px;\n  overflow: hidden;\n  border: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n\/* El haz de luz roja que da vueltas *\/\n.neon-red-flow {\n  position: absolute;\n  width: 150px;\n  height: 500px;\n  background: linear-gradient(#ff0000, #ff0000);\n  animation: girar 3s linear infinite;\n}\n\n\/* Efecto difuminado para que la luz roja sea \"ne\u00f3n\" *\/\n.neon-red-flow::after {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background: #ff0000;\n  filter: blur(25px);\n  opacity: 0.8;\n}\n\n@keyframes girar {\n  from { transform: rotate(0deg); }\n  to { transform: rotate(360deg); }\n}\n\n\/* El hueco interno transparente entre la luz y el bot\u00f3n *\/\n.marco-premium::before {\n  content: '';\n  position: absolute;\n  inset: 5px; \/* Espacio est\u00e9tico donde se ve la luz *\/\n  background: rgba(0, 0, 0, 0.2); \/* Negro muy suave y transparente *\/\n  border-radius: 12px;\n  z-index: 1;\n}\n\n\/* El bot\u00f3n blanco llamativo *\/\n.boton-blanco-top {\n  position: relative;\n  z-index: 2;\n  padding: 12px 35px;\n  background: #ffffff; \/* Blanco s\u00f3lido mantenido *\/\n  color: #000000;\n  text-decoration: none;\n  font-family: 'Arial', sans-serif;\n  font-weight: 900;\n  font-size: 17px;\n  letter-spacing: 1px;\n  border-radius: 8px;\n  transition: 0.4s;\n  box-shadow: 0 5px 15px rgba(0,0,0,0.4);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n\/* Efecto cuando pasas el mouse *\/\n.boton-blanco-top:hover {\n  transform: scale(1.08);\n  background: #ff0000;\n  color: #ffffff;\n  box-shadow: 0 0 20px #ff0000;\n}\n<\/style>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-51870ce e-grid e-con-full e-con e-child\" data-id=\"51870ce\" data-element_type=\"container\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;}\">\n\t\t<div class=\"elementor-element elementor-element-2a53a5d e-con-full e-flex e-con e-child\" data-id=\"2a53a5d\" data-element_type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-32d18ab elementor-widget elementor-widget-heading\" data-id=\"32d18ab\" data-element_type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">FAQ MERC<br>FULLFILLMENT<\/h2>\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-dc4403a elementor-widget elementor-widget-accordion\" data-id=\"dc4403a\" data-element_type=\"widget\" data-widget_type=\"accordion.default\">\n\t\t\t\t\t\t\t<div class=\"elementor-accordion\">\n\t\t\t\t\t\t\t<div class=\"elementor-accordion-item\">\n\t\t\t\t\t<div id=\"elementor-tab-title-2301\" class=\"elementor-tab-title\" data-tab=\"1\" role=\"button\" aria-controls=\"elementor-tab-content-2301\" aria-expanded=\"false\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon elementor-accordion-icon-right\" aria-hidden=\"true\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon-closed\"><svg class=\"e-font-icon-svg e-fas-plus\" viewBox=\"0 0 448 512\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\"><path d=\"M416 208H272V64c0-17.67-14.33-32-32-32h-32c-17.67 0-32 14.33-32 32v144H32c-17.67 0-32 14.3