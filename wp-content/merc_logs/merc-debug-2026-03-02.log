ifa-valor-small\">S\/ 2.20<\/div>\r\n                <div class=\"tarifa-rango-small\">0 - 15 KM<\/div>\r\n                <div class=\"progreso-bar-small\"><div class=\"llenado red\"><\/div><\/div>\r\n            <\/div>\r\n\r\n            <div class=\"tarifa-card-small destacada\">\r\n                <div class=\"tarifa-valor-small\">S\/ 2.00<\/div>\r\n                <div class=\"tarifa-rango-small\">15 KM A M\u00c1S<\/div>\r\n                <div class=\"progreso-bar-small\"><div class=\"llenado glow\"><\/div><\/div>\r\n            <\/div>\r\n        <\/div>\r\n\r\n        <a href=\"https:\/\/wa.me\/51931430389?text=Hola,%20\u00bfc\u00f3mo%20est\u00e1n?%20Me%20gustar\u00eda%20solicitar%20el%20servicio%20MERC%20Express.%20Requiero%20inmediatez%20para%20un%20env\u00edo%20y%20me%20interesa%20la%20modalidad%20de%20entrega%20directa%20personalizada.\" class=\"btn-cotizar-km-small\" target=\"_blank\">\r\n            <svg viewBox=\"0 0 24 24\" width=\"16\" height=\"16\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\">\r\n                <path d=\"M5 12h14M12 5l7 7-7 7\"\/>\r\n            <\/svg>\r\n            COTIZAR AHORA\r\n        <\/a>\r\n    <\/div>\r\n<\/div>\r\n\r\n<style>\r\n    .contenedor-dinamico-km-small {\r\n        width: 100%;\r\n        max-width: 550px; \r\n        margin: 20px auto;\r\n        padding: 0 10px;\r\n        box-sizing: border-box;\r\n        font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif;\r\n    }\r\n\r\n    .glass-tarifador-small {\r\n        background: rgba(30, 30, 30, 0.4); \/* Fondo un poco m\u00e1s oscuro para contraste *\/\r\n        backdrop-filter: blur(25px);\r\n        -webkit-backdrop-filter: blur(25px);\r\n        border: 1px solid rgba(255, 255, 255, 0.15);\r\n        border-radius: 25px;\r\n        padding: 25px;\r\n        text-align: center;\r\n        box-shadow: 0 15px 35px rgba(0,0,0,0.4);\r\n    }\r\n\r\n    .info-superior-small h3 {\r\n        color: #ffffff;\r\n        font-size: clamp(15px, 4.5vw, 18px);\r\n        margin: 0 0 10px 0;\r\n        text-transform: uppercase;\r\n        letter-spacing: 1.5px;\r\n        font-weight: 800;\r\n    }\r\n\r\n    .linea-roja-center {\r\n        width: 50px;\r\n        height: 4px;\r\n        background: #ff0000;\r\n        margin: 0 auto 20px;\r\n        border-radius: 10px;\r\n        box-shadow: 0 0 10px rgba(255, 0, 0, 0.8);\r\n    }\r\n\r\n    .grid-tarifas-small {\r\n        display: grid;\r\n        grid-template-columns: repeat(2, 1fr); \r\n        gap: 15px;\r\n        margin-bottom: 25px;\r\n    }\r\n\r\n    .tarifa-card-small {\r\n        background: rgba(255, 255, 255, 0.1); \/* M\u00e1s visible *\/\r\n        border: 1px solid rgba(255, 255, 255, 0.1);\r\n        padding: 15px;\r\n        border-radius: 18px;\r\n        display: flex;\r\n        flex-direction: column;\r\n        align-items: center;\r\n    }\r\n\r\n    .tarifa-card-small.destacada {\r\n        background: rgba(255, 0, 0, 0.1);\r\n        border-color: rgba(255, 0, 0, 0.4);\r\n    }\r\n\r\n    .tarifa-valor-small {\r\n        color: #ffffff;\r\n        font-size: clamp(20px, 6vw, 24px);\r\n        font-weight: 900;\r\n        margin-bottom: 2px;\r\n    }\r\n\r\n    \/* TEXTO DE KIL\u00d3METROS MUCHO M\u00c1S VISIBLE *\/\r\n    .tarifa-rango-small {\r\n        color: #ff4d4d; \/* Rojo ne\u00f3n m\u00e1s claro *\/\r\n        font-weight: 800;\r\n        font-size: 13px; \/* Aumentado *\/\r\n        margin-bottom: 10px;\r\n        letter-spacing: 0.5px;\r\n        text-shadow: 0 0 5px rgba(0,0,0,0.5); \/* Sombra para resaltar sobre el fondo *\/\r\n    }\r\n\r\n    .progreso-bar-small {\r\n        width: 100%;\r\n        height: 5px;\r\n        background: rgba(255, 255, 255, 0.2);\r\n        border-radius: 10px;\r\n        overflow: hidden;\r\n    }\r\n\r\n    .llenado { height: 100%; border-radius: 10px; }\r\n    .llenado.red { width: 45%; background: #ff0000; }\r\n    .llenado.glow { width: 100%; background: #ff0000; box-shadow: 0 0 10px #ff0000; }\r\n\r\n    .btn-cotizar-km-small {\r\n        display: inline-flex;\r\n        align-items: center;\r\n        justify-content: center;\r\n        gap: 10px;\r\n        background: #ffffff;\r\n        color: #000000;\r\n        text-decoration: none;\r\n        padding: 14px 25px;\r\n        border-radius: 15px;\r\n        font-weight: 900;\r\n        font-size: 13px;\r\n        transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);\r\n        width: 100%;\r\n        max-width: 280px;\r\n        box-sizing: border-box;\r\n        text-transform: uppercase;\r\n    }\r\n\r\n    .btn-cotizar-km-small:hover {\r\n        background: #ff0000;\r\n        color: #ffffff;\r\n        transform: translateY(-3px);\r\n        box-shadow: 0 10px 20px rgba(255, 0, 0, 0.4);\r\n    }\r\n\r\n    @media (max-width: 450px) {\r\n        .grid-tarifas-small {\r\n            grid-template-columns: 1fr;\r\n        }\r\n    }\r\n<\/style>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-413e025 e-con-full e-flex e-con e-child\" data-id=\"413e025\" data-element_type=\"container\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;}\">\n\t\t<div class=\"elementor-element elementor-element-6add54b e-grid e-con-full e-con e-child\" data-id=\"6add54b\" data-element_type=\"container\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;}\">\n\t\t<div class=\"elementor-element elementor-element-1ba9ff4 e-con-full e-flex e-con e-child\" data-id=\"1ba9ff4\" data-element_type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-7b1acbd elementor-widget elementor-widget-heading\" data-id=\"7b1acbd\" data-element_type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">FAQ MERC EXPRESS<\/h2>\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-a44a4b7 elementor-widget elementor-widget-accordion\" data-id=\"a44a4b7\" data-element_type=\"widget\" data-widget_type=\"accordion.default\">\n\t\t\t\t\t\t\t<div class=\"elementor-accordion\">\n\t\t\t\t\t\t\t<div class=\"elementor-accordion-item\">\n\t\t\t\t\t<div id=\"elementor-tab-title-1721\" class=\"elementor-tab-title\" data-tab=\"1\" role=\"button\" aria-controls=\"elementor-tab-content-1721\" aria-expanded=\"false\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon elementor-accordion-icon-right\" aria-hidden=\"true\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon-closed\"><svg class=\"e-font-icon-svg e-fas-plus\" viewBox=\"0 0 448 512\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\"><path d=\"M416 208H272V64c0-17.67-14.33-32-32-32h-32c-17.67 0-32 14.33-32 32v144H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h144v144c0 17.67 14.33 32 32 32h32c17.67 0 32-14.33 32-32V304h144c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z\"><\/path><\/svg><\/span>\n\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon-opened\"><svg class=\"e-font-icon-svg e-fas-minus\" viewBox=\"0 0 448 512\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\"><path d=\"M416 208H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h384c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z\"><\/path><\/svg><\/span>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<\/span>\n\t\t\t\t\t\t\t\t\t\t\t\t<a class=\"elementor-accordion-title\" tabindex=\"0\">\u00bfC\u00f3mo funciona la modalidad de trabajo y los horarios?<\/a>\n\t\t\t\t\t<\/div>\n\t\t\t\t\t<div id=\"elementor-tab-content-1721\" class=\"elementor-tab-content elementor-clearfix\" data-tab=\"1\" role=\"region\" aria-labelledby=\"elementor-tab-title-1721\"><p><span data-path-to-node=\"5,2\"><span class=\"citation-287\">Para acceder a este servicio, <i><b>debes solicitarlo con una hora de anticipaci\u00f3n dentro del rango horario de 10:00 am a 5:00 pm,<\/b><\/i> asegurando as\u00ed una <i><b>entrega directa que toma entre 1 a 2 horas de acuerdo a la distancia del destino<\/b><\/i><\/span><\/span><span data-path-to-node=\"5,4\"><i><b>.<\/b><\/i><\/span><\/p><\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t\t\t<div class=\"elementor-accordion-item\">\n\t\t\t\t\t<div id=\"elementor-tab-title-1722\" class=\"elementor-tab-title\" data-tab=\"2\" role=\"button\" aria-controls=\"elementor-tab-content-1722\" aria-expanded=\"false\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon elementor-accordion-icon-right\" aria-hidden=\"true\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon-closed\"><svg class=\"e-font-icon-svg e-fas-plus\" viewBox=\"0 0 448 512\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\"><path d=\"M416 208H272V64c0-17.67-14.33-32-32-32h-32c-17.67 0-32 14.33-32 32v144H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h144v144c0 17.67 14.33 32 32 32h32c17.67 0 32-14.33 32-32V304h144c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z\"><\/path><\/svg><\/span>\n\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon-opened\"><svg class=\"e-font-icon-svg e-fas-minus\" viewBox=\"0 0 448 512\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\"><path d=\"M416 208H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h384c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z\"><\/path><\/svg><\/span>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<\/span>\n\t\t\t\t\t\t\t\t\t\t\t\t<a class=\"elementor-accordion-title\" tabindex=\"0\">\u00bfCu\u00e1les son las tarifas y costos por kil\u00f3metro?<\/a>\n\t\t\t\t\t<\/div>\n\t\t\t\t\t<div id=\"elementor-tab-content-1722\" class=\"elementor-tab-content elementor-clearfix\" data-tab=\"2\" role=\"region\" aria-labelledby=\"elementor-tab-title-1722\"><p data-path-to-node=\"4\"><span data-path-to-node=\"6,2\"><span class=\"citation-286\">El costo se calcula mediante una tarifa por kilometraje de S\/ 2.50 por km, con un <i><b>monto m\u00ednimo de servicio de S\/ 10.00,<\/b><\/i> y en caso de que la entrega supere los 20 kil\u00f3metros, la tarifa se reduce a S\/ 2.00 por cada kil\u00f3metro recorrido<\/span><\/span><span data-path-to-node=\"6,4\">.<\/span><\/p><\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t\t\t<div class=\"elementor-accordion-item\">\n\t\t\t\t\t<div id=\"elementor-tab-title-1723\" class=\"elementor-tab-title\" data-tab=\"3\" role=\"button\" aria-controls=\"elementor-tab-content-1723\" aria-expanded=\"false\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon elementor-accordion-icon-right\" aria-hidden=\"true\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon-closed\"><svg class=\"e-font-icon-svg e-fas-plus\" viewBox=\"0 0 448 512\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\"><path d=\"M416 208H272V64c0-17.67-14.33-32-32-32h-32c-17.67 0-32 14.33-32 32v144H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h144v144c0 17.67 14.33 32 32 32h32c17.67 0 32-14.33 32-32V304h144c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z\"><\/path><\/svg><\/span>\n\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon-opened\"><svg class=\"e-font-icon-svg e-fas-minus\" viewBox=\"0 0 448 512\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\"><path d=\"M416 208H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h384c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z\"><\/path><\/svg><\/span>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<\/span>\n\t\t\t\t\t\t\t\t\t\t\t\t<a class=\"elementor-accordion-title\" tabindex=\"0\">\u00bfQu\u00e9 seguridad y opciones de pago ofrece para mi negocio?<\/a>\n\t\t\t\t\t<\/div>\n\t\t\t\t\t<div id=\"elementor-tab-content-1723\" class=\"elementor-tab-content elementor-clearfix\" data-tab=\"3\" role=\"region\" aria-labelledby=\"elementor-tab-title-1723\"><p data-path-to-node=\"6\"><span data-path-to-node=\"7,2\"><span class=\"citation-285\"><b><i>Este servicio incluye un seguro gratuito que cubre el valor real de tus productos hasta por S\/ 300.00 ante robo, p\u00e9rdida o da\u00f1os,<\/i><\/b> y adem\u00e1s te permite realizar ventas por <i><b>contra entreg<\/b><\/i>a con dep\u00f3sitos de tu dinero el mismo d\u00eda mediante diversos medios de pago como efectivo o tarjetas<\/span><\/span><span data-path-to-node=\"7,4\">.<\/span><\/p><\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-5846cad e-con-full e-flex e-con e-child\" data-id=\"5846cad\" data-element_type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-c3a2d05 elementor-widget elementor-widget-image\" data-id=\"c3a2d05\" data-element_type=\"widget\" data-widget_type=\"image.default\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<img width=\"1024\" height=\"1024\" src=\"https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-20-at-7.17.19-PM-1.jpeg\" class=\"attachment-large size-large wp-image-6479\" alt=\"\" srcset=\"https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-20-at-7.17.19-PM-1.jpeg 1024w, https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-20-at-7.17.19-PM-1-300x300.jpeg 300w, https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-20-at-7.17.19-PM-1-150x150.jpeg 150w, https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-20-at-7.17.19-PM-1-768x768.jpeg 768w\" sizes=\"(max-width: 1024px) 100vw, 1024px\" \/>\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t","scripts":[],"styles":[]}}
