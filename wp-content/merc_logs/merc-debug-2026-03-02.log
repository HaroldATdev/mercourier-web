n><\/li>\r\n            <\/ul>\r\n        <\/div>\r\n    <\/div>\r\n<\/div>\r\n\r\n<style>\r\n    .contenedor-liquid-glass {\r\n        padding: 40px 15px;\r\n        font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif;\r\n        max-width: 1200px;\r\n        margin: 0 auto;\r\n    }\r\n\r\n    .capsula-titulo-glass {\r\n        background: rgba(255, 255, 255, 0.05);\r\n        backdrop-filter: blur(20px);\r\n        -webkit-backdrop-filter: blur(20px);\r\n        border: 1px solid rgba(255, 255, 255, 0.1);\r\n        padding: 25px 40px;\r\n        border-radius: 40px;\r\n        margin: 0 auto 50px auto;\r\n        text-align: center;\r\n        width: fit-content;\r\n    }\r\n\r\n    .titulo-iphone-pro {\r\n        color: #fff;\r\n        font-size: 28px;\r\n        font-weight: 800;\r\n        text-transform: uppercase;\r\n        margin: 0;\r\n        background: linear-gradient(180deg, #fff 0%, #aaa 100%);\r\n        -webkit-background-clip: text;\r\n        -webkit-text-fill-color: transparent;\r\n    }\r\n\r\n    .linea-decorativa {\r\n        width: 60px; height: 4px; background: #ff0000;\r\n        margin: 12px auto 0; border-radius: 10px;\r\n        box-shadow: 0 0 15px rgba(255, 0, 0, 0.8);\r\n    }\r\n\r\n    .grid-glass {\r\n        display: grid;\r\n        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\r\n        gap: 25px;\r\n    }\r\n\r\n    .card-glass {\r\n        background: rgba(255, 255, 255, 0.03);\r\n        backdrop-filter: blur(25px);\r\n        -webkit-backdrop-filter: blur(25px);\r\n        border-radius: 30px;\r\n        padding: 25px;\r\n        border: 1px solid rgba(255, 255, 255, 0.08);\r\n    }\r\n\r\n    .badge-zona {\r\n        background: #ff0000;\r\n        color: #fff;\r\n        padding: 6px 14px;\r\n        border-radius: 12px;\r\n        font-size: 11px;\r\n        font-weight: 900;\r\n        margin-bottom: 20px;\r\n        display: inline-block;\r\n        letter-spacing: 1px;\r\n    }\r\n\r\n    .card-glass ul { list-style: none; padding: 0; margin: 0; }\r\n\r\n    .card-glass ul li {\r\n        color: rgba(255, 255, 255, 0.9);\r\n        font-size: 14px;\r\n        font-weight: 500;\r\n        padding: 12px 0;\r\n        border-bottom: 1px solid rgba(255, 255, 255, 0.05);\r\n        display: flex;\r\n        justify-content: space-between;\r\n        align-items: center;\r\n    }\r\n\r\n    \/* PRECIO CON EFECTO LIQUID GLASS REAL *\/\r\n    .precio-liquid-glass {\r\n        background: rgba(255, 255, 255, 0.15); \/* Efecto vidrio *\/\r\n        backdrop-filter: blur(10px);\r\n        -webkit-backdrop-filter: blur(10px);\r\n        border: 1px solid rgba(255, 255, 255, 0.3); \/* Brillo en el borde *\/\r\n        color: #ffffff;\r\n        font-weight: 800;\r\n        font-size: 13px;\r\n        padding: 5px 12px;\r\n        border-radius: 12px;\r\n        min-width: 70px;\r\n        text-align: center;\r\n        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);\r\n        transition: all 0.3s ease;\r\n    }\r\n\r\n    .card-glass ul li:hover .precio-liquid-glass {\r\n        background: rgba(255, 255, 255, 0.25);\r\n        border-color: #ff0000;\r\n        transform: scale(1.05);\r\n    }\r\n\r\n    @media (max-width: 600px) {\r\n        .grid-glass { grid-template-columns: 1fr; }\r\n    }\r\n<\/style>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t","scripts":[],"styles":[]}}
