content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-20-at-7.17.17-PM.jpeg\" class=\"attachment-large size-large wp-image-6485\" alt=\"\" srcset=\"https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-20-at-7.17.17-PM.jpeg 1024w, https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-20-at-7.17.17-PM-300x300.jpeg 300w, https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-20-at-7.17.17-PM-150x150.jpeg 150w, https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-20-at-7.17.17-PM-768x768.jpeg 768w\" sizes=\"(max-width: 1024px) 100vw, 1024px\" \/>\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-c12edff e-con-full e-flex e-con e-child\" data-id=\"c12edff\" data-element_type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-99798a8 elementor-widget elementor-widget-heading\" data-id=\"99798a8\" data-element_type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">MERC AGENCIA<\/h2>\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-66e396d e-con-full e-flex e-con e-child\" data-id=\"66e396d\" data-element_type=\"container\">\n\t\t[elementor-element k=\"f0ed140f8b6c5ed68b460c37d284d5b3\" data=\"\"]\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-62cf443 elementor-widget__width-initial elementor-widget elementor-widget-html\" data-id=\"62cf443\" data-element_type=\"widget\" data-widget_type=\"html.default\">\n\t\t\t\t\t<div class=\"marco-premium\">\n  <div class=\"neon-red-flow\"><\/div>\n  \n  <a href=\"https:\/\/wa.me\/51931430389?text=Hola,%20\u00bfc\u00f3mo%20est\u00e1n?%20Me%20gustar\u00eda%20solicitar%20el%20servicio%20MERC%20Agencia.%20Me%20interesa%20la%20modalidad%20de%20entrega%20de%20paquetes%20directamente%20en%20su%20sede%20para%20acceder%20a%20su%20tarifa%20m\u00e1s%20econ\u00f3mica.\" \n  class=\"boton-blanco-top\" target=\"_blank\">\n    COTIZA AHORA\n  <\/a>\n<\/div>\n\n<style>\n\/* Contenedor principal con fondo transparente *\/\n.marco-premium {\n  position: relative;\n  width: 290px;\n  height: 85px;\n  background: transparent; \/* Fondo transparente como pediste *\/\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  border-radius: 15px;\n  overflow: hidden;\n  border: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n\/* El haz de luz roja que da vueltas *\/\n.neon-red-flow {\n  position: absolute;\n  width: 150px;\n  height: 500px;\n  background: linear-gradient(#ff0000, #ff0000);\n  animation: girar 3s linear infinite;\n}\n\n\/* Efecto difuminado para que la luz roja sea \"ne\u00f3n\" *\/\n.neon-red-flow::after {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background: #ff0000;\n  filter: blur(25px);\n  opacity: 0.8;\n}\n\n@keyframes girar {\n  from { transform: rotate(0deg); }\n  to { transform: rotate(360deg); }\n}\n\n\/* El hueco interno transparente entre la luz y el bot\u00f3n *\/\n.marco-premium::before {\n  content: '';\n  position: absolute;\n  inset: 5px; \/* Espacio est\u00e9tico donde se ve la luz *\/\n  background: rgba(0, 0, 0, 0.2); \/* Negro muy suave y transparente *\/\n  border-radius: 12px;\n  z-index: 1;\n}\n\n\/* El bot\u00f3n blanco llamativo *\/\n.boton-blanco-top {\n  position: relative;\n  z-index: 2;\n  padding: 12px 35px;\n  background: #ffffff; \/* Blanco s\u00f3lido mantenido *\/\n  color: #000000;\n  text-decoration: none;\n  font-family: 'Arial', sans-serif;\n  font-weight: 900;\n  font-size: 17px;\n  letter-spacing: 1px;\n  border-radius: 8px;\n  transition: 0.4s;\n  box-shadow: 0 5px 15px rgba(0,0,0,0.4);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n\/* Efecto cuando pasas el mouse *\/\n.boton-blanco-top:hover {\n  transform: scale(1.08);\n  background: #ff0000;\n  color: #ffffff;\n  box-shadow: 0 0 20px #ff0000;\n}\n<\/style>\t\t\t\t<\/div