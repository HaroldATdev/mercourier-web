li>\r\n            <\/ul>\r\n        <\/div>\r\n\r\n        <div class=\"card-glass\">\r\n            <div class=\"contenedor-badges\">\r\n                <div class=\"badge-zona\">ZONA CENTRO<\/div>\r\n                <div class=\"badge-tarifa\">TARIFA PLANA S\/ 10.00<\/div>\r\n            <\/div>\r\n            <ul>\r\n                <li>Jes\u00fas Mar\u00eda<\/li>\r\n                <li>Lince<\/li>\r\n                <li>La Victoria<\/li>\r\n                <li>Miraflores<\/li>\r\n                <li>San Isidro<\/li>\r\n                <li>Surquillo<\/li>\r\n                <li>San Borja<\/li>\r\n                <li>San Luis<\/li>\r\n                <li>Centro de Lima<\/li>\r\n            <\/ul>\r\n        <\/div>\r\n    <\/div>\r\n<\/div>\r\n\r\n<style>\r\n    .contenedor-liquid-glass {\r\n        padding: 40px 15px;\r\n        font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, sans-serif;\r\n        max-width: 1200px;\r\n        margin: 0 auto;\r\n        display: flex;\r\n        flex-direction: column;\r\n        align-items: center;\r\n    }\r\n\r\n    .capsula-titulo-glass {\r\n        background: rgba(255, 255, 255, 0.05);\r\n        backdrop-filter: blur(20px);\r\n        -webkit-backdrop-filter: blur(20px);\r\n        border: 1px solid rgba(255, 255, 255, 0.1);\r\n        padding: 25px 40px;\r\n        border-radius: 40px;\r\n        margin-bottom: 50px;\r\n        text-align: center;\r\n    }\r\n\r\n    .titulo-iphone-pro {\r\n        color: #fff;\r\n        font-size: 28px;\r\n        font-weight: 700;\r\n        text-transform: uppercase;\r\n        margin: 0;\r\n        background: linear-gradient(180deg, #fff 0%, #aaa 100%);\r\n        -webkit-background-clip: text;\r\n        -webkit-text-fill-color: transparent;\r\n    }\r\n\r\n    .linea-decorativa {\r\n        width: 50px; height: 4px; background: #ff0000;\r\n        margin: 10px auto 0; border-radius: 10px;\r\n        box-shadow: 0 0 10px #ff0000;\r\n    }\r\n\r\n    .grid-glass {\r\n        display: grid;\r\n        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));\r\n        gap: 25px;\r\n        width: 100%;\r\n    }\r\n\r\n    .card-glass {\r\n        background: rgba(255, 255, 255, 0.06);\r\n        backdrop-filter: blur(20px);\r\n        -webkit-backdrop-filter: blur(20px);\r\n        border-radius: 25px;\r\n        padding: 25px;\r\n        border: 1px solid rgba(255, 255, 255, 0.1);\r\n    }\r\n\r\n    \/* Contenedor para alinear los dos cuadros arriba *\/\r\n    .contenedor-badges {\r\n        display: flex;\r\n        gap: 10px;\r\n        margin-bottom: 20px;\r\n        flex-wrap: wrap;\r\n    }\r\n\r\n    .badge-zona {\r\n        background: #ff0000;\r\n        color: #fff;\r\n        padding: 6px 12px;\r\n        border-radius: 8px;\r\n        font-size: 11px;\r\n        font-weight: 900;\r\n    }\r\n\r\n    .badge-tarifa {\r\n        background: rgba(255, 255, 255, 0.1);\r\n        color: #fff;\r\n        padding: 6px 12px;\r\n        border-radius: 8px;\r\n        font-size: 11px;\r\n        font-weight: 900;\r\n        border: 1px solid rgba(255, 255, 255, 0.2);\r\n    }\r\n\r\n    .card-glass ul { list-style: none; padding: 0; margin: 0; }\r\n\r\n    .card-glass ul li {\r\n        color: #eee;\r\n        font-size: 14px;\r\n        padding: 10px 0;\r\n        border-bottom: 1px solid rgba(255, 255, 255, 0.05);\r\n        text-align: left;\r\n    }\r\n\r\n    .card-glass ul li:last-child { border-bottom: none; }\r\n\r\n    @media (max-width: 600px) {\r\n        .grid-glass { grid-template-columns: 1fr; }\r\n        .card-glass { max-width: 100%; }\r\n    }\r\n<\/style>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t","scripts":[],"styles":[]}}
