[28-Feb-2026 23:59:01 UTC] MERC_DEBUG_META_UPDATE - meta_id=30115 post_id=3072 meta_key=_elementor_element_cache meta_value={"timeout":1772391541,"value":{"content":"<div class=\"elementor-element elementor-element-e10589a e-con-full e-flex e-con e-parent\" data-id=\"e10589a\" data-element_type=\"container\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;}\">\n\t\t\t\t<div class=\"elementor-element elementor-element-ef20a51 elementor-widget elementor-widget-html\" data-id=\"ef20a51\" data-element_type=\"widget\" data-widget_type=\"html.default\">\n\t\t\t\t\t<style>\r\n  \/* ======== ESTILOS GENERALES ======== *\/\r\n  .carrusel-container {\r\n    position: relative;\r\n    width: 100%;\r\n    height: 100vh;\r\n    margin: 0;\r\n    padding: 0;\r\n    overflow: hidden;\r\n    background-color: #000;\r\n  }\r\n\r\n  .carrusel-slide {\r\n    position: absolute;\r\n    inset: 0;\r\n    background-size: cover;\r\n    background-position: center;\r\n    opacity: 0;\r\n    transition: opacity 1s ease-in-out;\r\n    display: flex;\r\n    align-items: center; \/* Centrado vertical *\/\r\n  }\r\n\r\n  .carrusel-slide.active {\r\n    opacity: 1;\r\n    z-index: 2;\r\n  }\r\n\r\n  \/* Capa opaca *\/\r\n  .carrusel-overlay {\r\n    position: absolute;\r\n    inset: 0;\r\n    background-color: rgba(73, 8, 10, 0.65);\r\n  }\r\n\r\n  \/* Contenido del texto: Posici\u00f3n original (izquierda) *\/\r\n  .carrusel-content {\r\n    position: relative;\r\n    z-index: 3;\r\n    padding-left: 10%; \/* Esto imita tu posici\u00f3n original del 30% de forma segura *\/\r\n    width: 100%;\r\n    max-width: 900px;\r\n    box-sizing: border-box;\r\n  }\r\n\r\n  .carrusel-content h2 {\r\n    color: #ffffff !important; \/* Blanco forzado *\/\r\n    font-size: 4rem;\r\n    margin-bottom: 25px;\r\n    line-height: 1.1;\r\n    font-family: 'Montserrat', Sans-Serif;\r\n    font-weight: 800;\r\n    text-align: left;\r\n    text-shadow: 2px 2px 10px rgba(0, 0, 0, 0.5);\r\n  }\r\n\r\n  \/* Botones *\/\r\n  .carrusel-buttons {\r\n    margin-top: 30px;\r\n    display: flex;\r\n    gap: 15px;\r\n    flex-wrap: wrap;\r\n  }\r\n\r\n  .carrusel-buttons .btn {\r\n    background-color: #e63946;\r\n    color: #ffffff !important;\r\n    border: none;\r\n    padding: 14px 30px;\r\n    border-radius: 8px;\r\n    font-weight: bold;\r\n    text-decoration: none;\r\n    transition: background-color 0.3s ease;\r\n    font-size: 1rem;\r\n    display: inline-block;\r\n  }\r\n\r\n  .carrusel-buttons .btn:hover {\r\n    background-color: #ff5b5b;\r\n  }\r\n\r\n  \/* Flechas *\/\r\n  .carrusel-arrow {\r\n    position: absolute;\r\n    top: 50%;\r\n    transform: translateY(-50%);\r\n    background-color: rgba(0, 0, 0, 0.5);\r\n    color: white;\r\n    border: none;\r\n    padding: 15px 20px;\r\n    font-size: 24px;\r\n    border-radius: 50%;\r\n    cursor: pointer;\r\n    z-index: 4;\r\n    transition: 0.3s;\r\n  }\r\n\r\n  .carrusel-arrow.left { left: 20px; }\r\n  .carrusel-arrow.right { right: 20px; }\r\n\r\n  \/* ======== AJUSTES PARA TABLET Y M\u00d3VIL (RESPONSIVE) ======== *\/\r\n  \r\n  \/* Tablets *\/\r\n  @media (max-width: 1024px) {\r\n    .carrusel-content {\r\n      padding-left: 5%;\r\n      max-width: 80%;\r\n    }\r\n    .carrusel-content h2 {\r\n      font-size: 3rem;\r\n    }\r\n  }\r\n\r\n  \/* Celulares *\/\r\n  @media (max-width: 768px) {\r\n    .carrusel-container {\r\n      height: 70vh; \/* Altura m\u00e1s c\u00f3moda para m\u00f3viles *\/\r\n    }\r\n    \r\n    .carrusel-content {\r\n      padding: 0 40px; \/* Centramos visualmente en m\u00f3viles para que no se corte *\/\r\n      text-align: center;\r\n      padding-left: 20px; \/* Ajuste para que no pegue al borde *\/\r\n    }\r\n\r\n    .carrusel-content h2 {\r\n      font-size: 1.8rem;\r\n      text-align: left; \/* Mantiene la alineaci\u00f3n izquierda si as\u00ed lo prefieres *\/\r\n    }\r\n\r\n    .carrusel-buttons {\r\n      justify-content: flex-start;\r\n    }\r\n\r\n    .carrusel-arrow {\r\n      padding: 10px 15px;\r\n      font-size: 18px;\r\n    }\r\n  }\r\n<\/style>\r\n\r\n<div class=\"carrusel-container\">\r\n  <div class=\"carrusel-slide active\" style=\"background-image: url('https:\/\/mercourier.com\/wp-content\/uploads\/2026\/01\/41-3.png');\">\r\n    <div class=\"carrusel-overlay\"><\/div>\r\n    <div class=\"carrusel-content\">\r\n      <h2>Entrega r\u00e1pida y segura en cada pedido<\/h2>\r\n      <div class=\"carrusel-buttons\">\r\n        <a href=\"https:\/\/mercourier.com\/contact\/\" class=\"btn\">Conoce m\u00e1s<\/a>\r\n        <a href=\"https:\/\/mercourier.com\/dashboard\/\" class=\"btn\">Zona de clientes<\/a>\r\n      <\/div>\r\n    <\/div>\r\n  <\/div>\r\n\r\n  <div class=\"carrusel-slide\" style=\"background-image: url('https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/1920x1080-img-para-pagina-MERC-1.png');\">\r\n    <div class=\"carrusel-overlay\"><\/div>\r\n    <div class=\"carrusel-content\">\r\n      <h2>Conectamos destinos, entregamos confianza<\/h2>\r\n    <\/div>\r\n  <\/div>\r\n\r\n  <div class=\"carrusel-slide\" style=\"background-image: url('https:\/\/mercourier.com\/wp-content\/uploads\/2026\/01\/11-1.png');\">\r\n    <div class=\"carrusel-overlay\"><\/div>\r\n    <div class=\"carrusel-content\">\r\n      <h2>Tu env\u00edo, nuestra prioridad<\/h2>\r\n    <\/div>\r\n  <\/div>\r\n\r\n  <button class=\"carrusel-arrow left\">&#10094;<\/button>\r\n  <button class=\"carrusel-arrow right\">&#10095;<\/button>\r\n<\/div>\r\n\r\n<script>\r\n  document.addEventListener(\"DOMContentLoaded\", function() {\r\n    const slides = document.querySelectorAll(\".carrusel-slide\");\r\n    const prevBtn = document.querySelector(\".carrusel-arrow.left\");\r\n    const nextBtn = document.querySelector(\".carrusel-arrow.right\");\r\n    let currentIndex = 0;\r\n\r\n    function showSlide(index) {\r\n      slides.forEach((slide, i) => {\r\n        slide.classList.remove(\"active\");\r\n        if (i === index) slide.classList.add(\"active\");\r\n      });\r\n    }\r\n\r\n    prevBtn.addEventListener(\"click\", () => {\r\n      currentIndex = (currentIndex - 1 + slides.length) % slides.length;\r\n      showSlide(currentIndex);\r\n    });\r\n\r\n    nextBtn.addEventListener(\"click\", () => {\r\n      currentIndex = (currentIndex + 1) % slides.length;\r\n      showSlide(currentIndex);\r\n    });\r\n\r\n    \/\/ Cambio autom\u00e1tico cada 6 segundos\r\n    setInterval(() => {\r\n      currentIndex = (currentIndex + 1) % slides.length;\r\n      showSlide(currentIndex);\r\n    }, 6000);\r\n  });\r\n<\/script>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-2313f1c e-flex e-con-boxed e-con e-parent\" data-id=\"2313f1c\" data-element_type=\"container\">\n\t\t\t\t\t<div class=\"e-con-inner\">\n\t\t\t\t<div class=\"elementor-element elementor-element-7231bc3 elementor-widget-divider--view-line elementor-widget elementor-widget-divider\" data-id=\"7231bc3\" data-element_type=\"widget\" data-widget_type=\"divider.default\">\n\t\t\t\t\t\t\t<div class=\"elementor-divider\">\n\t\t\t<span class=\"elementor-divider-separator\">\n\t\t\t\t\t\t<\/span>\n\t\t<\/div>\n\t\t\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-6632840 elementor-widget elementor-widget-heading\" data-id=\"6632840\" data-element_type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">TRACKING MERCOURIER<\/h2>\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-ba4811b e-con-full e-flex e-con e-parent\" data-id=\"ba4811b\" data-element_type=\"container\">\n\t\t<div class=\"elementor-element elementor-element-20a50ec e-con-full e-flex e-con e-child\" data-id=\"20a50ec\" data-element_type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-e61c0f7 elementor-widget elementor-widget-html\" data-id=\"e61c0f7\" data-element_type=\"widget\" data-widget_type=\"html.default\">\n\t\t\t\t\t<div class=\"container-premium-grande\">\r\n    <div class=\"glass-bg-extra\"><\/div>\r\n    \r\n    <div class=\"image-frame-extra\">\r\n        <img src=\"https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-17-at-12.20.32-PM.jpeg\" alt=\"Courier Olva\">\r\n    <\/div>\r\n<\/div>\r\n\r\n<style>\r\n    \/* Contenedor principal m\u00e1s amplio *\/\r\n    .container-premium-grande {\r\n        position: relative;\r\n        width: 100%;\r\n        max-width: 900px; \/* Aumentado de 650px a 900px *\/\r\n        height: 550px;    \/* Aumentado de 400px a 550px *\/\r\n        margin: 60px auto;\r\n        display: flex;\r\n        align-items: center;\r\n        justify-content: center;\r\n        perspective: 1200px; \/* Profundidad mejorada para el tama\u00f1o grande *\/\r\n    }\r\n\r\n    \/* Fondo Rojo Liquid Glass *\/\r\n    .glass-bg-extra {\r\n        position: absolute;\r\n        width: 95%;\r\n        height: 90%;\r\n        background: rgba(227, 6, 19, 0.88);\r\n        \r\n        \/* Efecto Liquid Glass *\/\r\n        backdrop-filter: blur(18px) saturate(180%);\r\n        -webkit-backdrop-filter: blur(18px) saturate(180%);\r\n        \r\n        \/* Bordes curvos profesionales *\/\r\n        border-radius: 60px 180px 70px 150px; \r\n        \r\n        \/* Inclinaci\u00f3n lateral (de costado) *\/\r\n        transform: rotateX(4deg) rotateY(-12deg) rotateZ(-2deg);\r\n        \r\n        border: 1.5px solid rgba(255, 255, 255, 0.3);\r\n        box-shadow: -30px 30px 60px rgba(0,0,0,0.25);\r\n        z-index: 1;\r\n        transition: all 0.7s cubic-bezier(0.2, 0.8, 0.2, 1);\r\n    }\r\n\r\n    \/* Marco de la Imagen *\/\r\n    .image-frame-extra {\r\n        position: relative;\r\n        width: 88%;\r\n        height: 85%;\r\n        z-index: 2;\r\n        overflow: hidden;\r\n        \r\n        \/* Curvas asim\u00e9tricas suaves *\/\r\n        border-radius: 50px 130px 50px 110px;\r\n        \r\n        \/* Inclinaci\u00f3n coordinada *\/\r\n        transform: rotateX(4deg) rotateY(-8deg);\r\n        box-shadow: 20px 25px 50px rgba(0,0,0,0.35);\r\n        transition: all 0.7s cubic-bezier(0.2, 0.8, 0.2, 1);\r\n    }\r\n\r\n    .image-frame-extra img {\r\n        width: 100%;\r\n        height: 100%;\r\n        object-fit: cover;\r\n        display: block;\r\n        transition: transform 0.8s ease;\r\n    }\r\n\r\n    \/* Interacci\u00f3n Hover *\/\r\n    .container-premium-grande:hover .glass-bg-extra {\r\n        transform: rotateX(0deg) rotateY(-4deg) rotateZ(0deg) scale(1.02);\r\n        background: rgba(227, 6, 19, 1);\r\n    }\r\n\r\n    .container-premium-grande:hover .image-frame-extra {\r\n        transform: rotateX(0deg) rotateY(0deg) scale(1.03);\r\n    }\r\n\r\n    .container-premium-grande:hover img {\r\n        transform: scale(1.1);\r\n    }\r\n\r\n    \/* Responsive: Se adapta a pantallas peque\u00f1as *\/\r\n    @media (max-width: 900px) {\r\n        .container-premium-grande {\r\n            height: 400px;\r\n            max-width: 95%;\r\n        }\r\n    }\r\n\r\n    @media (max-width: 480px) {\r\n        .container-premium-grande {\r\n            height: 300px;\r\n            perspective: none;\r\n        }\r\n        .glass-bg-extra, .image-frame-extra {\r\n            border-radius: 30px 80px 30px 70px;\r\n            transform: rotate(-2deg);\r\n        }\r\n    }\r\n<\/style>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-99cfa00 e-con-full e-flex e-con e-child\" data-id=\"99cfa00\" data-element_type=\"container\">\n\t\t<div class=\"elementor-element elementor-element-596ae6e e-con-full e-flex e-con e-child\" data-id=\"596ae6e\" data-element_type=\"container\">\n\t\t[elementor-element k=\"f0ed140f8b6c5ed68b460c37d284d5b3\" data=\"eyJpZCI6IjQ3OGMwYjkiLCJlbFR5cGUiOiJ3aWRnZXQiLCJzZXR0aW5ncyI6eyJzaG9ydGNvZGUiOiJbd3BjYXJnb190cmFja2Zvcm1dIn0sImVsZW1lbnRzIjpbXSwid2lkZ2V0VHlwZSI6InNob3J0Y29kZSJ9\"]\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-c2f5d6c e-con-full e-flex e-con e-parent\" data-id=\"c2f5d6c\" data-element_type=\"container\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;}\">\n\t\t<div class=\"elementor-element elementor-element-af6d2a1 e-con-full e-flex e-con e-child\" data-id=\"af6d2a1\" data-element_type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-7115544 elementor-widget elementor-widget-heading\" data-id=\"7115544\" data-element_type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">Nuestros Servicios<\/h2>\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-9eaedad elementor-widget elementor-widget-html\" data-id=\"9eaedad\" data-element_type=\"widget\" data-widget_type=\"html.default\">\n\t\t\t\t\t<div class=\"merc-servicios-wrapper\">\r\n  <div class=\"servicios-loop-container\" id=\"carrusel-drag\">\r\n    <div class=\"servicios-track\" id=\"track\">\r\n      <\/div>\r\n  <\/div>\r\n<\/div>\r\n\r\n<style>\r\n\/* Wrapper principal *\/\r\n.merc-servicios-wrapper {\r\n  width: 100%;\r\n  margin: 0 auto;\r\n  background: transparent;\r\n  padding: 50px 0;\r\n}\r\n\r\n.merc-servicios-wrapper .servicios-loop-container {\r\n  overflow-x: auto;\r\n  scrollbar-width: none;\r\n  -ms-overflow-style: none;\r\n  cursor: grab;\r\n  user-select: none;\r\n}\r\n\r\n.merc-servicios-wrapper .servicios-loop-container::-webkit-scrollbar {\r\n  display: none;\r\n}\r\n\r\n.merc-servicios-wrapper .servicios-track {\r\n  display: flex;\r\n  \/* Espaciado amplio entre tarjetas solicitado *\/\r\n  gap: 80px; \r\n  animation: merc-scroll-infinito 40s linear infinite;\r\n}\r\n\r\n.merc-servicios-wrapper .servicio-card {\r\n  \/* Ancho amplio para evitar que se vea amontonado *\/\r\n  width: 420px; \r\n  background: #111;\r\n  border-radius: 15px;\r\n  overflow: hidden;\r\n  border: 1px solid #333;\r\n  border-bottom: 6px solid #49080A;\r\n  flex-shrink: 0;\r\n  transition: transform 0.4s ease, border-color 0.4s ease;\r\n}\r\n\r\n.merc-servicios-wrapper .servicio-card:hover {\r\n  transform: translateY(-12px);\r\n  border-color: #49080A;\r\n}\r\n\r\n.merc-servicios-wrapper .servicio-card img {\r\n  width: 100%;\r\n  height: 240px;\r\n  object-fit: cover;\r\n}\r\n\r\n.merc-servicios-wrapper .card-body { \r\n  padding: 35px; \r\n}\r\n\r\n.merc-servicios-wrapper .tag { \r\n  color: #ff5b5b; \r\n  font-size: 11px; \r\n  font-weight: bold; \r\n  letter-spacing: 3px; \r\n  text-transform: uppercase;\r\n}\r\n\r\n.merc-servicios-wrapper .card-body h3 { \r\n  color: #fff !important; \/* Aseguramos color blanco *\/\r\n  font-family: 'Montserrat', Sans-Serif; \r\n  margin: 15px 0; \r\n  font-size: 1.6rem; \r\n}\r\n\r\n.merc-servicios-wrapper .card-body p { \r\n  color: #ccc; \r\n  font-size: 1rem; \r\n  margin-bottom: 25px; \r\n  line-height: 1.7; \r\n}\r\n\r\n.merc-servicios-wrapper .btn-card {\r\n  display: inline-block;\r\n  padding: 14px 28px;\r\n  background: #49080A;\r\n  color: #fff !important;\r\n  text-decoration: none;\r\n  font-weight: bold;\r\n  border-radius: 8px;\r\n  font-size: 0.95rem;\r\n  transition: background 0.3s;\r\n}\r\n\r\n.merc-servicios-wrapper .btn-card:hover {\r\n  background: #e63946;\r\n}\r\n\r\n\/* --- ANIMACI\u00d3N MATEM\u00c1TICA --- *\/\r\n@keyframes merc-scroll-infinito {\r\n  0% { transform: translateX(0); }\r\n  100% { transform: translateX(calc((-420px - 80px) * 4)); }\r\n}\r\n\r\n.merc-servicios-wrapper .servicios-loop-container:hover .servicios-track {\r\n  animation-play-state: paused;\r\n}\r\n\r\n\/* ======== RESPONSIVE ======== *\/\r\n@media (max-width: 1024px) {\r\n  .merc-servicios-wrapper .servicio-card {\r\n    width: 350px;\r\n  }\r\n  @keyframes merc-scroll-infinito {\r\n    0% { transform: translateX(0); }\r\n    100% { transform: translateX(calc((-350px - 80px) * 4)); }\r\n  }\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .merc-servicios-wrapper .servicio-card {\r\n    width: 300px;\r\n  }\r\n  .merc-servicios-wrapper .servicios-track {\r\n    gap: 40px;\r\n  }\r\n  @keyframes merc-scroll-infinito {\r\n    0% { transform: translateX(0); }\r\n    100% { transform: translateX(calc((-300px - 40px) * 4)); }\r\n  }\r\n}\r\n<\/style>\r\n\r\n<script>\r\n(function() {\r\n  const servicios = [\r\n    {\r\n      img: 'https:\/\/mercourier.com\/wp-content\/uploads\/2026\/01\/IMAGENES-PAGINA-1024X1024.png',\r\n      alt: 'Merc Emprendedor',\r\n      titulo: 'MERC EMPRENDEDOR',\r\n      descripcion: '<strong>MERC EMPRENDEDOR<\/strong> es un servicio con tarifa plana de S\/10. Ofrece recojo matutino, entrega por la tarde y seguro gratuito hasta S\/300.',\r\n      enlace: 'https:\/\/mercourier.com\/merc-emprendedor\/'\r\n    },\r\n    {\r\n      img: 'https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/3.png',\r\n      alt: 'Merc Agencia',\r\n      titulo: 'MERC AGENCIA',\r\n      descripcion: '<strong>MERC AGENCIA<\/strong> ofrece env\u00edos con tarifa plana de S\/8. Recibe pedidos hasta las 12:30 pm e incluye seguro de S\/300.',\r\n      enlace: 'https:\/\/mercourier.com\/merc-agencia\/'\r\n    },\r\n    {\r\n      img: 'https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/4.png',\r\n      alt: 'Merc Express',\r\n      titulo: 'MERC EXPRESS',\r\n      descripcion: '<strong>MERC EXPRESS<\/strong> es entrega personalizada en 1 a 2 horas. Cuesta S\/2.50 por km y ofrece seguro de S\/300.',\r\n      enlace: 'https:\/\/mercourier.com\/merc-express\/'\r\n    },\r\n    {\r\n      img: 'https:\/\/mercourier.com\/wp-content\/uploads\/2026\/01\/11.png',\r\n      alt: 'Merc Fullfillment',\r\n      titulo: 'MERC FULLFILLMENT',\r\n      descripcion: '<strong>MERC FULFILLMENT<\/strong> gestiona almacenamiento e inventario. Ofrece entregas el mismo d\u00eda y seguro de S\/300.',\r\n      enlace: 'https:\/\/mercourier.com\/merc-fullfitment\/'\r\n    }\r\n  ];\r\n\r\n  function crearCard(servicio) {\r\n    return `\r\n      <div class=\"servicio-card\">\r\n        <img src=\"${servicio.img}\" alt=\"${servicio.alt}\">\r\n        <div class=\"card-body\">\r\n          <span class=\"tag\">SERVICIO ESPECIALIZADO<\/span>\r\n          <h3>${servicio.titulo}<\/h3>\r\n          <p>${servicio.descripcion}<\/p>\r\n          <a href=\"${servicio.enlace}\" class=\"btn-card\">Saber m\u00e1s<\/a>\r\n        <\/div>\r\n      <\/div>\r\n    `;\r\n  }\r\n\r\n  const track = document.querySelector('.merc-servicios-wrapper .servicios-track');\r\n  if (!track) return;\r\n\r\n  let cardsHTML = '';\r\n  \/\/ Bucle infinito\r\n  for (let i = 0; i < 10; i++) {\r\n    servicios.forEach(servicio => {\r\n      cardsHTML += crearCard(servicio);\r\n    });\r\n  }\r\n  \r\n  track.innerHTML = cardsHTML;\r\n\r\n  \/\/ L\u00f3gica de arrastre\r\n  const slider = document.querySelector('.merc-servicios-wrapper .servicios-loop-container');\r\n  let isDown = false;\r\n  let startX;\r\n  let scrollLeft;\r\n\r\n  slider.addEventListener('mousedown', (e) => {\r\n    isDown = true;\r\n    slider.style.cursor = 'grabbing';\r\n    track.style.animationPlayState = 'paused';\r\n    startX = e.pageX - slider.offsetLeft;\r\n    scrollLeft = slider.scrollLeft;\r\n  });\r\n\r\n  const endDragging = () => {\r\n    isDown = false;\r\n    slider.style.cursor = 'grab';\r\n    if (!slider.matches(':hover')) track.style.animationPlayState = 'running';\r\n  };\r\n\r\n  slider.addEventListener('mouseleave', endDragging);\r\n  slider.addEventListener('mouseup', endDragging);\r\n\r\n  slider.addEventListener('mousemove', (e) => {\r\n    if (!isDown) return;\r\n    e.preventDefault();\r\n    const x = e.pageX - slider.offsetLeft;\r\n    const walk = (x - startX) * 2;\r\n    slider.scrollLeft = scrollLeft - walk;\r\n  });\r\n})();\r\n<\/script>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-b7c2168 e-flex e-con-boxed elementor-invisible e-con e-parent\" data-id=\"b7c2168\" data-element_type=\"container\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;,&quot;animation&quot;:&quot;fadeIn&quot;}\">\n\t\t\t\t\t<div class=\"e-con-inner\">\n\t\t\t\t<div class=\"elementor-element elementor-element-12da26a elementor-position-top elementor-widget elementor-widget-image-box\" data-id=\"12da26a\" data-element_type=\"widget\" data-widget_type=\"image-box.default\">\n\t\t\t\t\t<div class=\"elementor-image-box-wrapper\"><figure class=\"elementor-image-box-img\"><img width=\"55\" height=\"49\" src=\"https:\/\/mercourier.com\/wp-content\/uploads\/2021\/12\/home-page-icon-1-white.svg\" class=\"attachment-full size-full wp-image-685\" alt=\"\" \/><\/figure><div class=\"elementor-image-box-content\"><h5 class=\"elementor-image-box-title\">Brindamos un seguro para todos tus productos<\/h5><\/div><\/div>\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-699aaf9 elementor-position-top elementor-widget elementor-widget-image-box\" data-id=\"699aaf9\" data-element_type=\"widget\" data-widget_type=\"image-box.default\">\n\t\t\t\t\t<div class=\"elementor-image-box-wrapper\"><figure class=\"elementor-image-box-img\"><img width=\"55\" height=\"56\" src=\"https:\/\/mercourier.com\/wp-content\/uploads\/2021\/12\/home-page-icon-2-white.svg\" class=\"attachment-full size-full wp-image-686\" alt=\"\" \/><\/figure><div class=\"elementor-image-box-content\"><h5 class=\"elementor-image-box-title\">Rembolsamos el valor de los productos extraviados<\/h5><\/div><\/div>\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-295c058 elementor-position-top elementor-widget elementor-widget-image-box\" data-id=\"295c058\" data-element_type=\"widget\" data-widget_type=\"image-box.default\">\n\t\t\t\t\t<div class=\"elementor-image-box-wrapper\"><figure class=\"elementor-image-box-img\"><img width=\"49\" height=\"56\" src=\"https:\/\/mercourier.com\/wp-content\/uploads\/2021\/12\/home-page-icon-3-white.svg\" class=\"attachment-full size-full wp-image-684\" alt=\"\" \/><\/figure><div class=\"elementor-image-box-content\"><h5 class=\"elementor-image-box-title\">Mayor tranquilidad y confianza a nuestros clientes<\/h5><\/div><\/div>\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-b85c483 e-flex e-con-boxed e-con e-parent\" data-id=\"b85c483\" data-element_type=\"container\">\n\t\t\t\t\t<div class=\"e-con-inner\">\n\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t","scripts":[],"styles":[]}}
