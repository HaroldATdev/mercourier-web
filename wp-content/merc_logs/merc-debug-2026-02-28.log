=\"neon-red-flow\"><\/div>\n  \n  <a href=\"https:\/\/wa.me\/51931430389?text=Hola,%20\u00bfc\u00f3mo%20est\u00e1n?%20Me%20gustar\u00eda%20solicitar%20el%20servicio%20MERC%20Fullfillment.%20Me%20interesa%20delegar%20mi%20operaci\u00f3n%20log\u00edstica,%20el%20almacenamiento%20estrat\u00e9gico%20de%20mis%20productos%20y%20la%20gesti\u00f3n%20integral%20de%20mi%20inventario.\" \n  class=\"boton-blanco-top\" target=\"_blank\">\n    COTIZA AHORA\n  <\/a>\n<\/div>\n\n<style>\n\/* Contenedor principal con fondo transparente *\/\n.marco-premium {\n  position: relative;\n  width: 290px;\n  height: 85px;\n  background: transparent; \/* Fondo transparente como pediste *\/\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  border-radius: 15px;\n  overflow: hidden;\n  border: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n\/* El haz de luz roja que da vueltas *\/\n.neon-red-flow {\n  position: absolute;\n  width: 150px;\n  height: 500px;\n  background: linear-gradient(#ff0000, #ff0000);\n  animation: girar 3s linear infinite;\n}\n\n\/* Efecto difuminado para que la luz roja sea \"ne\u00f3n\" *\/\n.neon-red-flow::after {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background: #ff0000;\n  filter: blur(25px);\n  opacity: 0.8;\n}\n\n@keyframes girar {\n  from { transform: rotate(0deg); }\n  to { transform: rotate(360deg); }\n}\n\n\/* El hueco interno transparente entre la luz y el bot\u00f3n *\/\n.marco-premium::before {\n  content: '';\n  position: absolute;\n  inset: 5px; \/* Espacio est\u00e9tico donde se ve la luz *\/\n  background: rgba(0, 0, 0, 0.2); \/* Negro muy suave y transparente *\/\n  border-radius: 12px;\n  z-index: 1;\n}\n\n\/* El bot\u00f3n blanco llamativo *\/\n.boton-blanco-top {\n  position: relative;\n  z-index: 2;\n  padding: 12px 35px;\n  background: #ffffff; \/* Blanco s\u00f3lido mantenido *\/\n  color: #000000;\n  text-decoration: none;\n  font-family: 'Arial', sans-serif;\n  font-weight: 900;\n  font-size: 17px;\n  letter-spacing: 1px;\n  border-radius: 8px;\n  transition: 0.4s;\n  box-shadow: 0 5px 15px rgba(0,0,0,0.4);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n\/* Efecto cuando pasas el mouse *\/\n.boton-blanco-top:hover {\n  transform: scale(1.08);\n  background: #ff0000;\n  color: #ffffff;\n  box-shadow: 0 0 20px #ff0000;\n}\n<\/style>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-51870ce e-grid e-con-full e-con e-child\" data-id=\"51870ce\" data-element_type=\"container\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;}\">\n\t\t<div class=\"elementor-element elementor-element-2a53a5d e-con-full e-flex e-con e-child\" data-id=\"2a53a5d\" data-element_type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-32d18ab elementor-widget elementor-widget-heading\" data-id=\"32d18ab\" data-element_type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">FAQ MERC<br>FULLFILLMENT<\/h2>\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-dc4403a elementor-widget elementor-widget-accordion\" data-id=\"dc4403a\" data-element_type=\"widget\" data-widget_type=\"accordion.default\">\n\t\t\t\t\t\t\t<div class=\"elementor-accordion\">\n\t\t\t\t\t\t\t<div class=\"elementor-accordion-item\">\n\t\t\t\t\t<div id=\"elementor-tab-title-2301\" class=\"elementor-tab-title\" data-tab=\"1\" role=\"button\" aria-controls=\"elementor-tab-content-2301\" aria-expanded=\"false\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon elementor-accordion-icon-right\" aria-hidden=\"true\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon-closed\"><svg class=\"e-font-icon-svg e-fas-plus\" viewBox=\"0 0 448 512\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\"><path d=\"M416 208H272V64c0-17.67-14.33-32-32-32h-32c-17.67 0-32 14.33-32 32v144H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h144v144c0 17.67 14.33 32 32 32h32c17.67 0 32-14.33 32-32V304h144c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z\"><\/path><\/svg><\/span>\n\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon-opened\"><svg class=\"e-font-icon-svg e-fas-minus\" viewBox=\"0 0 448 512\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\"><path d=\"M416 208H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h384c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z\"><\/path><\/svg><\/span>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<\/span>\n\t\t\t\t\t\t\t\t\t\t\t\t<a class=\"elementor-accordion-title\" tabindex=\"0\">\u00bfC\u00f3mo funciona la modalidad de trabajo y los horarios?<\/a>\n\t\t\t\t\t<\/div>\n\t\t\t\t\t<div id=\"elementor-tab-content-2301\" class=\"elementor-tab-content elementor-clearfix\" data-tab=\"1\" role=\"region\" aria-labelledby=\"elementor-tab-title-2301\"><p><span data-path-to-node=\"5,2\"><span class=\"citation-312\">Para acceder a este servicio, debes solicitarlo a m\u00e1s tardar a las 11:30 am del mismo d\u00eda, permiti\u00e9ndonos preparar tus productos para que las entregas se realicen esa misma tarde en el rango horario de 2:00 pm a 7:30 pm seg\u00fan la ruta establecida<\/span><\/span><span data-path-to-node=\"5,4\">.<\/span><\/p><\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t\t\t<div class=\"elementor-accordion-item\">\n\t\t\t\t\t<div id=\"elementor-tab-title-2302\" class=\"elementor-tab-title\" data-tab=\"2\" role=\"button\" aria-controls=\"elementor-tab-content-2302\" aria-expanded=\"false\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon elementor-accordion-icon-right\" aria-hidden=\"true\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon-closed\"><svg class=\"e-font-icon-svg e-fas-plus\" viewBox=\"0 0 448 512\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\"><path d=\"M416 208H272V64c0-17.67-14.33-32-32-32h-32c-17.67 0-32 14.33-32 32v144H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h144v144c0 17.67 14.33 32 32 32h32c17.67 0 32-14.33 32-32V304h144c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z\"><\/path><\/svg><\/span>\n\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon-opened\"><svg class=\"e-font-icon-svg e-fas-minus\" viewBox=\"0 0 448 512\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\"><path d=\"M416 208H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h384c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z\"><\/path><\/svg><\/span>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<\/span>\n\t\t\t\t\t\t\t\t\t\t\t\t<a class=\"elementor-accordion-title\" tabindex=\"0\">\u00bfCu\u00e1les son las tarifas y condiciones de empaquetado?<\/a>\n\t\t\t\t\t<\/div>\n\t\t\t\t\t<div id=\"elementor-tab-content-2302\" class=\"elementor-tab-content elementor-clearfix\" data-tab=\"2\" role=\"region\" aria-labelledby=\"elementor-tab-title-2302\"><p data-path-to-node=\"4\"><span data-path-to-node=\"6,2\"><span class=\"citation-311\">Ofrecemos una tarifa plana de S\/ 10.00 para toda Lima Metropolitana y Callao sin exigir un m\u00ednimo de env\u00edos, encarg\u00e1ndonos del empaquetado y rotulado de acuerdo a la presentaci\u00f3n de tu marca, siempre que los paquetes respeten las medidas m\u00e1ximas de 25 cm por lado y un peso de hasta 3 kilos<\/span><\/span><span data-path-to-node=\"6,4\">.<\/span><\/p><\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t\t\t<div class=\"elementor-accordion-item\">\n\t\t\t\t\t<div id=\"elementor-tab-title-2303\" class=\"elementor-tab-title\" data-tab=\"3\" role=\"button\" aria-controls=\"elementor-tab-content-2303\" aria-expanded=\"false\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon elementor-accordion-icon-right\" aria-hidden=\"true\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon-closed\"><svg class=\"e-font-icon-svg e-fas-plus\" viewBox=\"0 0 448 512\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\"><path d=\"M416 208H272V64c0-17.67-14.33-32-32-32h-32c-17.67 0-32 14.33-32 32v144H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h144v144c0 17.67 14.33 32 32 32h32c17.67 0 32-14.33 32-32V304h144c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z\"><\/path><\/svg><\/span>\n\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon-opened\"><svg class=\"e-font-icon-svg e-fas-minus\" viewBox=\"0 0 448 512\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\"><path d=\"M416 208H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h384c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z\"><\/path><\/svg><\/span>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<\/span>\n\t\t\t\t\t\t\t\t\t\t\t\t<a class=\"elementor-accordion-title\" tabindex=\"0\">\u00bfQu\u00e9 seguridad y opciones de pago ofrece para mi negocio?<\/a>\n\t\t\t\t\t<\/div>\n\t\t\t\t\t<div id=\"elementor-tab-content-2303\" class=\"elementor-tab-content elementor-clearfix\" data-tab=\"3\" role=\"region\" aria-labelledby=\"elementor-tab-title-2303\"><p data-path-to-node=\"6\"><span data-path-to-node=\"7,2\"><span class=\"citation-310\">Este servicio te brinda la tranquilidad de un seguro gratuito que cubre el valor real de tus productos hasta por S\/ 300.00 ante robo o da\u00f1os, adem\u00e1s de facilitar el cobro de tus ventas mediante contra entrega con el dep\u00f3sito de tu dinero el mismo d\u00eda a trav\u00e9s de efectivo, Yape o tarjetas<\/span><\/span><span data-path-to-node=\"7,4\">.<\/span><\/p><\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-164612a e-con-full e-flex e-con e-child\" data-id=\"164612a\" data-element_type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-a0dd2df elementor-widget elementor-widget-image\" data-id=\"a0dd2df\" data-element_type=\"widget\" data-widget_type=\"image.default\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<img width=\"1024\" height=\"1024\" src=\"https:\/\/mercourier.com\/wp-content\/uploads\/2026\/02\/WhatsApp-Image-2026-02-20-at-7.17.19-PM-2.jpeg\" class=\"attachment-large size-large wp-image-6490\" alt=\"\" srcset=\"https:\/\