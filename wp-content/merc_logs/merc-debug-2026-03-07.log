[07-Mar-2026 05:17:05 UTC] 🔍 [MERC_ADMIN_CARDS] drivers_sql: SELECT COALESCE(pm_driver.meta_value, pm_driver_alt.meta_value) AS driver_id, COUNT(DISTINCT p.ID) AS total_entregas FROM wp_posts p LEFT JOIN wp_postmeta pm_driver ON p.ID = pm_driver.post_id AND pm_driver.meta_key = 'wpcargo_driver' LEFT JOIN wp_postmeta pm_driver_alt ON p.ID = pm_driver_alt.post_id AND pm_driver_alt.meta_key = 'wpcargo_motorizo_recojo' WHERE p.post_type = 'wpcargo_shipment' AND p.post_status = 'publish' AND (pm_driver.meta_value IS NOT NULL OR pm_driver_alt.meta_value IS NOT NULL) AND ( EXISTS( SELECT 1 FROM wp_postmeta pm_pickup WHERE pm_pickup.post_id = p.ID AND pm_pickup.meta_key IN ('wpcargo_pickup_date_picker','wpcargo_pickup_date','calendarenvio','wpcargo_fecha_envio') AND ( (STR_TO_DATE(pm_pickup.meta_value, '%%d/%%m/%%Y') >= STR_TO_DATE('2026-03-05', '%%Y-%%m-%%d') AND STR_TO_DATE(pm_pickup.meta_value, '%%d/%%m/%%Y') <= STR_TO_DATE('2026-03-05', '%%Y-%%m-%%d')) OR (STR_TO_DATE(pm_pickup.meta_value, '%%Y-%%m-%%d') >= STR_TO_DATE('2026-03-05', '%%Y-%%m-%%d') AND STR_TO_DATE(pm_pickup.meta_value, '%%Y-%%m-%%d') <= STR_TO_DATE('2026-03-05', '%%Y-%%m-%%d')) OR (pm_pickup.meta_value BETWEEN '2026-03-05' AND '2026-03-05') OR (pm_pickup.meta_value LIKE '2026-03-05%') ) ) OR (p.post_date BETWEEN '2026-03-05 00:00:00' AND '2026-03-05 23:59:59') ) GROUP BY COALESCE(pm_driver.meta_value, pm_driver_alt.meta_value) ORDER BY total_entregas DESC
