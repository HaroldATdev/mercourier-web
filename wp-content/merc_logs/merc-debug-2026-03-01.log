[01-Mar-2026 13:56:44 UTC] 👤 Motorizado actual: ID 50
[01-Mar-2026 13:56:44 UTC] MERC_PLANIFICADOR_SQL - SELECT DISTINCT p.ID, p.post_title
        FROM wp_posts p
        LEFT JOIN wp_postmeta pm_driver ON p.ID = pm_driver.post_id AND pm_driver.meta_key = 'wpcargo_driver'
        LEFT JOIN wp_postmeta pm_pickup ON p.ID = pm_pickup.post_id AND pm_pickup.meta_key IN ('wpcargo_pickup_date_picker','wpcargo_pickup_date','calendarenvio','wpcargo_fecha_envio')
        LEFT JOIN wp_postmeta pm_status ON p.ID = pm_status.post_id AND pm_status.meta_key = 'wpcargo_status'
        LEFT JOIN wp_postmeta pm_tipo ON p.ID = pm_tipo.post_id AND pm_tipo.meta_key = 'tipo_envio'
        WHERE p.post_type = 'wpcargo_shipment'
        AND p.post_status = 'publish'
        AND pm_driver.meta_value = 50
        AND (
            (STR_TO_DATE(pm_pickup.meta_value, '{16ce95d2dba8fc32457e1a47d06aeef47f718a5ff3cfd30b0c663fe211043771}d/{16ce95d2dba8fc32457e1a47d06aeef47f718a5ff3cfd30b0c663fe211043771}m/{16ce95d2dba8fc32457e1a47d06aeef47f718a5ff3cfd30b0c663fe211043771}Y') = STR_TO_DATE('2026-03-01', '{16ce95d2dba8fc32457e1a47d06aeef47f718a5ff3cfd30b0c663fe211043771}Y-{16ce95d2dba8fc32457e1a47d06aeef47f718a5ff3cfd30b0c663fe211043771}m-{16ce95d2dba8fc32457e1a47d06aeef47f718a5ff3cfd30b0c663fe211043771}d'))
            OR (STR_TO_DATE(pm_pickup.meta_value, '{16ce95d2dba8fc32457e1a47d06aeef47f718a5ff3cfd30b0c663fe211043771}Y-{16ce95d2dba8fc32457e1a47d06aeef47f718a5ff3cfd30b0c663fe211043771}m-{16ce95d2dba8fc32457e1a47d06aeef47f718a5ff3cfd30b0c663fe211043771}d') = STR_TO_DATE('2026-03-01', '{16ce95d2dba8fc32457e1a47d06aeef47f718a5ff3cfd30b0c663fe211043771}Y-{16ce95d2dba8fc32457e1a47d06aeef47f718a5ff3cfd30b0c663fe211043771}m-{16ce95d2dba8fc32457e1a47d06aeef47f718a5ff3cfd30b0c663fe211043771}d'))
            OR pm_pickup.meta_value LIKE '01/03/2026{16ce95d2dba8fc32457e1a47d06aeef47f718a5ff3cfd30b0c663fe211043771}'
        )
        AND LOWER(IFNULL(pm_tipo.meta_value, '')) = 'normal'
        AND UPPER(IFNULL(pm_status.meta_value, '')) = 'PENDIENTE'
        ORDER BY p.ID ASC
