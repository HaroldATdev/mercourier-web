S\/%2010%20para%20Lima%20y%20Callao%20con%20entrega%20el%20mismo%20d\u00eda.%F0%9F%93%A6%E2%9C%A8\" \n  class=\"boton-blanco-top\" target=\"_blank\">\n    COTIZA AHORA\n  <\/a>\n<\/div>\n\n<style>\n\/* Contenedor principal con fondo transparente *\/\n.marco-premium {\n  position: relative;\n  width: 290px;\n  height: 85px;\n  background: transparent; \/* Fondo transparente como pediste *\/\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  border-radius: 15px;\n  overflow: hidden;\n  border: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n\/* El haz de luz roja que da vueltas *\/\n.neon-red-flow {\n  position: absolute;\n  width: 150px;\n  height: 500px;\n  background: linear-gradient(#ff0000, #ff0000);\n  animation: girar 3s linear infinite;\n}\n\n\/* Efecto difuminado para que la luz roja sea \"ne\u00f3n\" *\/\n.neon-red-flow::after {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background: #ff0000;\n  filter: blur(25px);\n  opacity: 0.8;\n}\n\n@keyframes girar {\n  from { transform: rotate(0deg); }\n  to { transform: rotate(360deg); }\n}\n\n\/* El hueco interno transparente entre la luz y el bot\u00f3n *\/\n.marco-premium::before {\n  content: '';\n  position: absolute;\n  inset: 5px; \/* Espacio est\u00e9tico donde se ve la luz *\/\n  background: rgba(0, 0, 0, 0.2); \/* Negro muy suave y transparente *\/\n  border-radius: 12px;\n  z-index: 1;\n}\n\n\/* El bot\u00f3n blanco llamativo *\/\n.boton-blanco-top {\n  position: relative;\n  z-index: 2;\n  padding: 12px 35px;\n  background: #ffffff; \/* Blanco s\u00f3lido mantenido *\/\n  color: #000000;\n  text-decoration: none;\n  font-family: 'Arial', sans-serif;\n  font-weight: 900;\n  font-size: 17px;\n  letter-spacing: 1px;\n  border-radius: 8px;\n  transition: 0.4s;\n  box-shadow: 0 5px 15px rgba(0,0,0,0.4);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n\/* Efecto cuando pasas el mouse *\/\n.boton-blanco-top:hover {\n  transform: scale(1.08);\n  background: #ff0000;\n  color: #ffffff;\n  box-shadow: 0 0 20px #ff0000;\n}\n<\/style>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-8e91e52 e-grid e-con-full e-con e-child\" data-id=\"8e91e52\" data-element_type=\"container\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;}\">\n\t\t<div class=\"elementor-element elementor-element-b4641fd e-con-full e-flex e-con e-child\" data-id=\"b4641fd\" data-element_type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-68543a8 elementor-widget elementor-widget-heading\" data-id=\"68543a8\" data-element_type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">FAQ MERC EMPRENDEDOR<\/h2>\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-a7379c2 elementor-widget elementor-widget-accordion\" data-id=\"a7379c2\" data-element_type=\"widget\" data-widget_type=\"accordion.default\">\n\t\t\t\t\t\t\t<div class=\"elementor-accordion\">\n\t\t\t\t\t\t\t<div class=\"elementor-accordion-item\">\n\t\t\t\t\t<div id=\"elementor-tab-title-1751\" class=\"elementor-tab-title\" data-tab=\"1\" role=\"button\" aria-controls=\"elementor-tab-content-1751\" aria-expanded=\"false\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon elementor-accordion-icon-right\" aria-hidden=\"true\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon-closed\"><svg class=\"e-font-icon-svg e-fas-plus\" viewBox=\"0 0 448 512\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\"><path d=\"M416 208H272V64c0-17.67-14.33-32-32-32h-32c-17.67 0-32 14.33-32 32v144H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h144v144c0 17.67 14.33 32 32 32h32c17.67 0 32-14.33 32-32V304h144c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z\"><\/path><\/svg><\/span>\n\t\t\t\t\t\t\t\t<span class=\"elementor-accordion-icon-opened\"><svg class=\"e-font-icon-svg e-fas-minus\"